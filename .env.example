# ── Base de datos PostgreSQL ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=monety_db
DB_USER=monety_user
DB_PASSWORD=tu_password_seguro
DB_SSL=false          # true en producción (Render, Railway, RDS, etc.)
DB_POOL_MAX=10
DB_POOL_IDLE=30000
DB_POOL_ACQUIRE=60000

# ── Servidor ──────────────────────────────────────────────────
NODE_ENV=development  # production | test
PORT=4000
API_PREFIX=/api/v1

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES=8h        # duración del token para usuarios internos

# ── CORS ──────────────────────────────────────────────────────
# Origenes permitidos separados por coma (sin espacios)
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,https://monety.mx

# ── Archivos / Storage ────────────────────────────────────────
UPLOAD_MAX_MB=10
# Para producción configura S3/GCS aquí:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET=monety-docs
# AWS_REGION=us-east-1

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
